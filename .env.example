# Copie este arquivo para `.env` e preencha sua credencial da Anthropic.
#   cp .env.example .env
#
# Use UMA das duas opções:
#   • API key da Console (recomendado): começa com sk-ant-api...
#     → preencha ANTHROPIC_API_KEY abaixo.
#   • OAuth token (ex.: gerado via `ant auth login` / Claude Code):
#     começa com sk-ant-oat... → preencha ANTHROPIC_AUTH_TOKEN.
#     (Se você colar um token sk-ant-oat... em ANTHROPIC_API_KEY, os scripts
#      detectam o prefixo e autenticam via Bearer automaticamente.)

ANTHROPIC_API_KEY=
# ANTHROPIC_AUTH_TOKEN=

# Opcional. Modelo usado por todos os exercícios.
# IMPORTANTE: ex02 (e o uso de `temperature` em geral) exige um modelo da
# família 4.x que aceite sampling. Os modelos Opus 4.7/4.8 e Fable 5 REJEITAM
# `temperature` (HTTP 400). Mantenha um modelo compatível aqui.
#   claude-sonnet-4-6  (default — aceita temperature, boa qualidade)
#   claude-haiku-4-5   (mais barato e rápido; variância ainda mais visível)
ANTHROPIC_MODEL=claude-sonnet-4-6
